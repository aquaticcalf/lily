{
  "name": "lily devcontainer",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:2": {
      "nodeGypDependencies": true,
      "version": "lts"
    },
    "ghcr.io/devcontainers-extra/features/expo-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers-extra/features/vercel-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainer-community/devcontainer-features/turso.tech:1": {
      "version": "latest"
    },
    "ghcr.io/helpers4/devcontainer/vite-plus:1": {
      "installVitePlus": true,
      "installGlobally": true
    }
  }
}
